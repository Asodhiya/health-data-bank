# ─── Database ───────────────────────────────────────────────
# When using docker compose these are overridden by the compose
# environment block. Only needed for manual (non-Docker) setup.
user=postgres
password=postgres
host=localhost
port=5432
dbname=healthdatabank
DB_SSLMODE=disable

# ─── Authentication / JWT ──────────────────────────────────
# Generate a secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── First Admin Bootstrap ─────────────────────────────────
# On first startup with a fresh DB, the app auto-creates an admin
# account using these values. If FIRST_ADMIN_PASSWORD is blank a
# random password is generated and printed in the backend logs.
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=
FIRST_ADMIN_FIRST_NAME=Admin
FIRST_ADMIN_LAST_NAME=User

# ─── Email (optional) ─────────────────────────────────────
# Used for password-reset and notification emails.
# Leave blank to skip email features.
EMAIL_USER=
EMAIL_PASS=

# ─── Frontend URL ─────────────────────────────────────────
# Used in password-reset links. Defaults to http://localhost:5173
FRONTEND_URL=http://localhost:5173
