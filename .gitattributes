# Auto-detect text files and normalize line endings to LF in the repo
* text=auto eol=lf

# Force LF for shell scripts (must not have CRLF)
*.sh text eol=lf

# Force LF for Python, JS, JSX, JSON, etc.
*.py text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.env text eol=lf
*.txt text eol=lf
*.css text eol=lf
*.html text eol=lf

# Treat binary files as binary (no line ending conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
